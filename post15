    <script>
        const slides = document.getElementById('slides');
        const images = slides.getElementsByTagName('img');
        const prev = document.getElementById('prev');
        const next = document.getElementById('next');
        let index = 0;

        function showSlide(i) {
            index = (i + images.length) % images.length;
            slides.style.transform = `translateX(-${index * 100}%)`;
        }

        prev.addEventListener('click', () => showSlide(index - 1));
        next.addEventListener('click', () => showSlide(index + 1));
    </script>
    <div class="progress-percentage" id="progress-percentage">0%</div>
    <script>
        const progressPercentage = document.getElementById("progress-percentage");

        window.addEventListener("scroll", () => {
            const scrollTop = window.scrollY;
            const docHeight = document.body.scrollHeight - window.innerHeight;
            const scrollPercent = Math.round((scrollTop / docHeight) * 100);

            // Update the percentage text
            progressPercentage.textContent = scrollPercent + "%";
        });
    </script>
    <script>
        const stars = document.querySelectorAll('.star');
        const ratingValue = document.getElementById('ratingValue');
        const submitRating = document.getElementById('submitRating');
        const modal = document.getElementById('thankYouModal');
        const userRating = document.getElementById('userRating');
        const closeModal = document.getElementById('closeModal');
        let selectedRating = 0;
        let ratings = JSON.parse(localStorage.getItem('ratings')) || [];

        // Highlight stars
        stars.forEach(star => {
            star.addEventListener('mouseover', () => updateStars(star.dataset.value));
            star.addEventListener('click', () => {
                selectedRating = parseInt(star.dataset.value);
                ratingValue.textContent = `Rating: ${selectedRating}`;
            });
        });

        // Update stars appearance
        function updateStars(rating) {
            stars.forEach(star => {
                star.classList.toggle('selected', star.dataset.value <= rating);
            });
        }

        // Submit rating
        submitRating.addEventListener('click', () => {
            if (selectedRating === 0) {
                alert('Please select a rating between 1 and 5.');
                return;
            }
            ratings.push(selectedRating);
            localStorage.setItem('ratings', JSON.stringify(ratings));
            showThankYouModal(selectedRating);
        });

        // Show Thank You Modal
        function showThankYouModal(rating) {
            userRating.textContent = rating;
            modal.style.display = 'flex';
        }

        // Close Modal
        closeModal.addEventListener('click', () => {
            modal.style.display = 'none';
        });

        // Close modal if clicked outside
        window.addEventListener('click', (event) => {
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        });
    </script>
