/* Container for the carousel */
        .carousel-container {
            position: relative;
            width: 100%;
            max-width: 1200px; /* Max width for larger screens */
            height: 60vh; /* Maintain aspect ratio */
            border-radius: 1rem; /* Rounded corners */
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); /* Shadow effect */
            background-color: #333; /* Fallback background */
            margin: 2rem auto; /* Add margin to center it and give some space */
        }

        /* Individual carousel item */
        .carousel-item {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0; /* Start hidden */
            visibility: hidden; /* Hide from screen readers and pointer events */
            transition: opacity 1s ease-in-out, visibility 1s ease-in-out; /* Smooth fade transition */
        }

        .carousel-item.active {
            opacity: 1; /* Fade in */
            visibility: visible; /* Make visible */
            display: block; /* Ensure it takes up space */
        }

        .carousel-item img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Cover the container */
        }

        /* Overlay gradient for text readability */
        .carousel-overlay {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(to top, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.3), transparent);
        }

        /* Text content within carousel item */
        .carousel-content {
            position: absolute;
            bottom: 0;
            left: 0;
            padding: 2rem; /* p-8 */
            color: #FFFFFF;
        }

        .carousel-tag {
            background-color: #0891B2; /* Accent color */
            color: #FFFFFF;
            font-size: 0.75rem; /* text-xs */
            font-weight: 700; /* font-bold */
            text-transform: uppercase;
            padding: 0.25rem 0.75rem; /* px-3 py-1 */
            border-radius: 9999px; /* rounded-full */
            display: inline-block; /* Ensure padding works */
        }
        .carousel-tag.new-release { background-color: #0891B2; } /* Vibrant Cyan */
        .carousel-tag.in-depth-guide { background-color: #F59E0B; } /* Amber */
        .carousel-tag.esports { background-color: #DB2777; } /* Pink */


        .carousel-title {
            font-family: 'Orbitron', sans-serif; /* Techy font for headings from Aether theme */
            font-size: 1.875rem; /* text-3xl */
            line-height: 2.25rem;
            font-weight: 900; /* font-black */
            margin-top: 1rem; /* mt-4 */
            max-width: 48rem; /* max-w-3xl */
        }

        .carousel-description {
            margin-top: 0.5rem; /* mt-2 */
            font-size: 1.125rem; /* text-lg */
            line-height: 1.75rem;
            color: #D1D5DB; /* text-gray-300 */
            max-width: 42rem; /* max-w-2xl */
        }

        /* Carousel controls */
        .carousel-controls {
            position: absolute;
            bottom: 2rem; /* bottom-8 */
            right: 2rem; /* right-8 */
            display: flex;
            gap: 0.75rem; /* space-x-3 */
        }

        .carousel-control-btn {
            background-color: rgba(255, 255, 255, 0.2); /* bg-white/20 */
            color: #FFFFFF;
            padding: 0.75rem; /* p-3 */
            border-radius: 9999px; /* rounded-full */
            border: none;
            cursor: pointer;
            transition: background-color 300ms ease-in-out;
            backdrop-filter: blur(4px); /* backdrop-blur-sm */
            -webkit-backdrop-filter: blur(4px); /* for Safari */
        }

        .carousel-control-btn:hover {
            background-color: rgba(255, 255, 255, 0.4); /* hover:bg-white/40 */
        }

        .carousel-control-btn svg {
            width: 1.5rem; /* w-6 */
            height: 1.5rem; /* h-6 */
        }

        /* Responsive adjustments */
        @media (min-width: 768px) { /* md breakpoint */
            .carousel-content {
                padding: 3rem; /* md:p-12 */
            }
            .carousel-title {
                font-size: 3rem; /* md:text-5xl */
                line-height: 1;
            }
            .carousel-description {
                display: block; /* md:block, default is hidden on small screens */
            }
        }
        @media (max-width: 767px) { /* hide description on small screens */
            .carousel-description {
                display: none;
            }
        }
