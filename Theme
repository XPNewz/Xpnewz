                if (!response.ok) {
                    throw new Error(`API call failed with status: ${response.status}`);
                }

                const result = await response.json();

                if (result.candidates &amp;&amp; result.candidates.length &gt; 0 &amp;&amp;
                    result.candidates[0].content &amp;&amp; result.candidates[0].content.parts &amp;&amp;
                    result.candidates[0].content.parts.length &gt; 0) {
                    return result.candidates[0].content.parts[0].text;
                } else {
                    console.error(&quot;Unexpected API response structure:&quot;, result);
                    return &quot;Sorry, something went wrong while generating the content.&quot;;
                }
            } catch (error) {
                console.error(&#39;Error calling Gemini API:&#39;, error);
                return `Sorry, there was an error. Please try again later. Details: ${error.message}`;
            }
        }


        // --- AI Summary Modal Logic ---
        const summaryModal = document.getElementById(&#39;summary-modal&#39;);
        const summaryModalContent = document.getElementById(&#39;summary-modal-content&#39;);
        const summarizeBtns = document.querySelectorAll(&#39;.summarize-btn&#39;);

        summarizeBtns.forEach(btn =&gt; {
            btn.addEventListener(&#39;click&#39;, async (e) =&gt; {
                const article = e.target.closest(&#39;article&#39;);
                const title = article.querySelector(&#39;.article-title&#39;).textContent;
                const content = article.querySelector(&#39;.article-content&#39;).textContent;

                // Show modal with loading state
                summaryModalContent.innerHTML = `
                    <div class='p-8'>
                        <div class='flex justify-between items-center mb-4'>
                            <h3 class='text-2xl font-bold font-orbitron text-accent'>&#10024; AI Summary</h3>
                            <button class='close-modal-btn text-gray-500 hover:text-black'>&#215;</button>
                        </div>
                        <h4 class='text-xl font-bold mb-4'>${title}</h4>
                        <div class='flex items-center justify-center h-32'>
                            <div class='loader'/>
                        </div>
                    </div>
                `;
                summaryModal.classList.remove(&#39;hidden&#39;);
                summaryModal.classList.add(&#39;modal-active&#39;);
                
                // Call Gemini API
                const prompt = `Summarize the following gaming article in 3 short, easy-to-read bullet points. Keep it concise and engaging. Article Title: &quot;${title}&quot;. Content: &quot;${content}&quot;`;
                const summary = await callGeminiAPI(prompt);
                
                // Update modal with summary
                summaryModalContent.innerHTML = `
                    <div class='p-6 md:p-8'>
                        <div class='flex justify-between items-center mb-4'>
                            <h3 class='text-2xl font-bold font-orbitron text-accent'>&#10024; AI Summary</h3>
                            <button class='close-modal-btn text-gray-500 hover:text-black text-3xl leading-none'>&#215;</button>
                        </div>
                        <h4 class='text-xl font-bold mb-4'>${title}</h4>
                        <div class='prose max-w-none text-gray-600'>${summary.replace(/\*/g, &#39;&#8226;&#39;)}</div>
                    </div>
                `;
            });
        });

        // Close modal listener (event delegation)
        summaryModal.addEventListener(&#39;click&#39;, (e) =&gt; {
            if (e.target.classList.contains(&#39;close-modal-btn&#39;) || e.target.id === &#39;summary-modal&#39;) {
                summaryModal.classList.add(&#39;hidden&#39;);
                summaryModal.classList.remove(&#39;modal-active&#39;);
            }
        });

        // --- AI Game Suggester Logic ---
        const generateGamesBtn = document.getElementById(&#39;generate-games-btn&#39;);
        const gamePromptInput = document.getElementById(&#39;game-prompt&#39;);
        const gameSuggestionsDiv = document.getElementById(&#39;game-suggestions&#39;);

        generateGamesBtn.addEventListener(&#39;click&#39;, async () =&gt; {
            const userPrompt = gamePromptInput.value.trim();
            if (!userPrompt) {
                gameSuggestionsDiv.innerHTML = `<p class='text-red-500 text-sm'>Please describe the type of game you&#39;d like to play.</p>`;
                return;
            }

            // Show loading state
            gameSuggestionsDiv.innerHTML = `
                <div class='flex items-center justify-center p-4'>
                    <div class='loader'/>
                </div>
            `;

           const prompt = `You are a helpful and knowledgeable gaming assistant. Based on the user&#39;s request, suggest exactly 3 video games. For each game, provide a one-sentence reason why it fits the description. Format the response as a list with the game title in bold. User Request: &quot;${userPrompt}&quot;`;
            const suggestions = await callGeminiAPI(prompt);

            // Display suggestions
            // Simple formatting to make it look nice
            const formattedSuggestions = suggestions
                .replace(/\*\*(.*?)\*\*/g, &#39;<strong class='text-gray-900'>$1</strong>&#39;) // Bold game titles
                .replace(/(\r\n|\n|\r)/g, &#39;<br/>&#39;); // Replace newlines with <br/> for HTML

            gameSuggestionsDiv.innerHTML = `<div class='text-sm text-gray-700 space-y-3 mt-2'>${formattedSuggestions}</div>`;
        });

    </script>
    <script>
        // --- Hero Carousel Logic ---
        const carouselItems = document.querySelectorAll(&#39;.carousel-item&#39;);
        const prevBtn = document.getElementById(&#39;prevBtn&#39;);
        const nextBtn = document.getElementById(&#39;nextBtn&#39;);
        let currentIndex = 0;
        let autoSlideInterval;

        /**
         * Displays the slide at the given index and hides others.
         * @param {number} index The index of the slide to show.
         */
        function showSlide(index) {
            console.log(`Showing slide: ${index}`); // Debugging log
            carouselItems.forEach((item, i) =&gt; {
                item.classList.remove(&#39;active&#39;);
            });
            if (carouselItems[index]) {
                carouselItems[index].classList.add(&#39;active&#39;);
            }
        }

        /**
         * Advances to the next slide in the carousel.
         */
        function nextSlide() {
            currentIndex = (currentIndex + 1) % carouselItems.length;
            showSlide(currentIndex);
            console.log(&#39;Next slide triggered. Current index:&#39;, currentIndex); // Debugging log
        }
        
        /**
         * Goes back to the previous slide in the carousel.
         */
        function prevSlide() {
            currentIndex = (currentIndex - 1 + carouselItems.length) % carouselItems.length;
            showSlide(currentIndex);
            console.log(&#39;Previous slide triggered. Current index:&#39;, currentIndex); // Debugging log
        }

        /**
         * Starts the automatic slide transition.
         */
        function startAutoSlide() {
             autoSlideInterval = setInterval(nextSlide, 5000); // Change slide every 5 seconds
             console.log(&#39;Auto-slide started.&#39;); // Debugging log
        }

        /**
         * Stops the automatic slide transition.
         */
        function stopAutoSlide() {
            clearInterval(autoSlideInterval);
            console.log(&#39;Auto-slide stopped.&#39;); // Debugging log
        }

        // Add event listeners for navigation buttons
        if(prevBtn &amp;&amp; nextBtn) {
            nextBtn.addEventListener(&#39;click&#39;, () =&gt; {
                nextSlide();
                stopAutoSlide(); // Stop auto-slide on manual interaction
                startAutoSlide(); // Restart auto-slide
            });

            prevBtn.addEventListener(&#39;click&#39;, () =&gt; {
                prevSlide();
                stopAutoSlide(); // Stop auto-slide on manual interaction
                startAutoSlide(); // Restart auto-slide
            });
        } else {
            console.error(&#39;Carousel navigation buttons not found!&#39;); // Error log if buttons are missing
        }
        
        // Initialize carousel: show the first slide and start auto-play
        showSlide(currentIndex);
        startAutoSlide();
    </script>
  </body>
</html>
